# BC-Bench Environment Variables
# Copy this file to .env and fill in your values

# Azure DevOps Personal Access Token (required for collecting NAV PRs)
ADO_TOKEN=your_ado_token_here

# BC Container Password (required when using --use-container)
BC_CONTAINER_PASSWORD=your_container_password_here

# Optional: Set to "1" to enable debug logging in GitHub Actions
# RUNNER_DEBUG=1

# Azure AI Foundry APIs
AZURE_API_BASE=your_azure_api_base_here
AZURE_API_KEY=your_azure_api_key_here
AZURE_API_VERSION=version